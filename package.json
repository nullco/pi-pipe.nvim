{
  "name": "pi-pipe.nvim",
  "version": "1.0.0",
  "private": true,
  "description": "Send code context from Neovim directly into your pi coding agent session",
  "keywords": [
    "pi-package",
    "neovim",
    "pi"
  ],
  "type": "module",
  "scripts": {
    "test:ts": "node --experimental-strip-types --test pi-extension/nvim-pi-pipe.test.ts",
    "test:nvim": "nvim --headless -u NONE -c \"set rtp+=$HOME/.local/share/nvim/lazy/plenary.nvim\" -c \"runtime plugin/plenary.vim\" -c \"PlenaryBustedFile spec/selection_spec.lua\" -c \"qa!\"",
    "test": "npm run test:ts && npm run test:nvim"
  },
  "pi": {
    "extensions": [
      "./pi-extension/nvim-pi-pipe.ts"
    ]
  }
}
